# Planning / working docs 
m_Docs/

# Claude Code project rules (local only)
CLAUDE.md

# Local CLI tool config (not project content)
.qwen/

.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# Tool caches (ruff/pytest/mypy — self-check tooling from CLAUDE.md)
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Environment / secrets
.env

# Personal tool registrations (local paths/binaries differ per machine) — see
# custom_tools.example.yaml for the committed template
/custom_tools.yaml

# Runtime session data (file-based storage, not committed)
data/sessions/*
!data/sessions/.gitkeep

# Maps session_id -> its real project folder (see sessions/store.py) — machine-specific paths
data/sessions_index.json

# Exploitation allowlist (managed only via the /settings UI, see agent/tools/allowed_targets.py)
data/allowed_targets.json

# Global LLM provider/model choice (managed via the /settings UI, see agent/settings.py)
data/llm_settings.json

# Debug logs (see agent/utils/debug.py) — dir is created on demand, no .gitkeep needed
data/debug.log
data/debug/*

# TTL cache for external lookups (see agent/tools/native.py)
data/cache/*
!data/cache/.gitkeep

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
