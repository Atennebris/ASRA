# LLM provider switch: qwen (default) or opencode-zen (free, no key needed for
# free models — handy fallback when Qwen quota runs out during dev/testing).
LLM_PROVIDER=qwen

QWEN_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional — free models (big-pickle, minimax-m2.5-free, etc.) work without a key.
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=big-pickle
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

PORT=8000

# Single target authorized for real exploitation (Metasploit). Recon/scan tools
# may run against any target from the form; exploit tools never run without this.
ALLOWED_TARGET=

MAX_ITERATIONS=20
ENABLE_EXPLOIT=true

TOOL_TIMEOUT_SECONDS=120
EXPLOIT_TIMEOUT_SECONDS=180
EXPLOIT_APPROVAL_TIMEOUT_SECONDS=300

# TTL for cached external lookups (crt.sh, wayback, exploit-db, cve, models.dev).
CACHE_TTL_SECONDS=3600

DEBUG=false
