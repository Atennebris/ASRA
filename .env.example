# LLM provider switch: opencode-zen (default — free, no key needed) or qwen.
LLM_PROVIDER=opencode-zen

# Create your own personal key:
#   1. Open https://modelstudio.console.alibabacloud.com/ (log in / create an Alibaba Cloud account if needed)
#   2. Left sidebar -> "Get Started" -> "First API call to Qwen"
#   3. On that page, "Account setup" section, step 3 "Get an API key" -> click the "API Key" link
#   4. On the API Key page, click "Create API Key"
# The key value is shown only once at creation — copy it into your local .env immediately.
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus
# Default endpoint below works for most accounts; if Model Studio shows you a
# dedicated workspace domain instead, use that "OpenAI Compatible Endpoint" URL here.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Default provider. Free, no key needed for big-pickle (or minimax-m2.5-free, etc.).
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=big-pickle
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# Port the FastAPI/uvicorn web server listens on.
PORT=8000

# Hard cap on LLM calls per scan session before the agent force-stops.
MAX_ITERATIONS=20
# Master switch for the exploitation step. false = detection + PoC only, no real exploitation.
ENABLE_EXPLOIT=true

# Max seconds a single recon/scan tool call (nmap, nuclei, native tools) may run before timeout.
TOOL_TIMEOUT_SECONDS=600
# Max seconds a single exploit-tool call (Metasploit, sqlmap) may run before timeout.
EXPLOIT_TIMEOUT_SECONDS=600
# Seconds to wait for human approval before a pending exploit attempt is skipped.
EXPLOIT_APPROVAL_TIMEOUT_SECONDS=300

# TTL for cached external lookups (crt.sh/certspotter, wayback, exploit-db, cve).
CACHE_TTL_SECONDS=3600
# TTL for the cached models.dev model-capabilities catalog — deliberately longer than
# CACHE_TTL_SECONDS above, the catalog is large and rarely changes.
MODELS_DEV_CACHE_TTL_SECONDS=86400

# true = verbose debug logging to data/debug.log + colorized per-category console output.
DEBUG=false
